# Oil & Gas Platform - Environment Configuration
# Copy this file to .env and fill in your values

# Optional: Anthropic API key for AI-powered daily summaries
# Get one free at https://console.anthropic.com
ANTHROPIC_API_KEY=your_key_here

# Optional: Telegram Bot for daily digest delivery
# Step 1: Message @BotFather on Telegram, send /newbot, follow steps → get TELEGRAM_BOT_TOKEN
# Step 2: Add your bot to a group/channel, then message it and visit:
#   https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates  to find your CHAT_ID
TELEGRAM_BOT_TOKEN=your_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Optional: GNews API key (free tier - 100 req/day)
# Get one at https://gnews.io
GNEWS_API_KEY=your_key_here

# Optional: NewsAPI key (free dev tier)
# Get one at https://newsapi.org
NEWS_API_KEY=your_key_here

# How often to fetch news (minutes)
FETCH_INTERVAL_MINUTES=15

# How many hours before an article is considered old
ARTICLE_MAX_AGE_HOURS=72

# Server settings
HOST=0.0.0.0
PORT=8000

# Daily summary time (24h format, local time)
DAILY_SUMMARY_TIME=07:00
